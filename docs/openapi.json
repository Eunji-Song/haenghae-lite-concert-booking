      "/api/v1/rankings/concerts/soldout": {
        "get": {
          "tags": [
            "콘서트 랭킹"
          ],
          "summary": "월별 빠른 매진 콘서트 랭킹 조회",
          "description": "주어진 month(yyyy-MM) 기준으로, 가장 빨리 매진된 콘서트 TOP N을 조회합니다.\n- Redis Sorted Set을 이용해 매진 시각(soldOutAt)을 score로 저장합니다.\n- score가 작을수록(더 이른 시각일수록) 높은 순위(1등)에 위치합니다.\n- month 파라미터가 비어있으면, 서버 기준 현재 월(예: Asia/Seoul)을 기본값으로 사용합니다.\n",
          "operationId": "getFastSoldOutRanking",
          "parameters": [
            {
              "name": "month",
              "in": "query",
              "description": "조회 대상 월 (yyyy-MM). 예: 2025-12. 비워두면 현재 월 기준.",
              "required": false,
              "schema": {
                "type": "string"
              }
            },
            {
              "name": "limit",
              "in": "query",
              "description": "조회할 랭킹 개수 (기본값 10)",
              "required": false,
              "schema": {
                "type": "integer",
                "format": "int32",
                "default": 10
              }
            }
          ],
          "responses": {
            "200": {
              "description": "OK",
              "content": {
                "*/*": {
                  "schema": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/FastSoldOutConcertResponse"
                    }
                  }
                }
              }
            }
          }
        }
      },
